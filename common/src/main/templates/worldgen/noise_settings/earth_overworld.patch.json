{
  "aquifers_enabled": false,
  "ore_veins_enabled": true,
  "sea_level": 63,
  "noise_router": {
    "continents": {
      "type": "terrarium_expanded:terrain_continentalness"
    },
    "depth": {
      "type": "terrarium_expanded:terrain_depth"
    },
    "erosion": {
      "type": "terrarium_expanded:terrain_erosion"
    },
    "preliminary_surface_level": {
      "type": "terrarium_expanded:terrain_envelope"
    },
    "final_density": {
      "$terrarium_expanded:replace": {
        "type": "terrarium_expanded:earth_surface_caves",
        "initial_density_without_jaggedness": {
          "$terrarium_expanded:copy": "/noise_router/initial_density_without_jaggedness"
        },
        "final_density": {
          "$terrarium_expanded:copy": "/noise_router/final_density"
        }
      }
    },
    "initial_density_without_jaggedness": {
      "$terrarium_expanded:replace": {
        "type": "terrarium_expanded:terrain_envelope"
      }
    },
    "ridges": {
      "type": "terrarium_expanded:terrain_weirdness"
    }
  }
}
